# Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# Admin Configuration (JSON format)
# Формат: ["user_id1", "user_id2"] или user_id1,user_id2
ADMIN_USER_IDS=["123456789"]

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=botdb
POSTGRES_USER=botuser
POSTGRES_PASSWORD=securepassword

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Environment
ENV=development

# Logging
LOG_LEVEL=INFO

# ========================================
# Local Bot API Settings (Optional)
# ========================================
# Для загрузки файлов до 2GB вместо 50MB
# Получить на https://my.telegram.org

USE_LOCAL_API=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
LOCAL_API_HOST=telegram-bot-api
LOCAL_API_PORT=8081

# ========================================
# AI Providers (Telegram Business mode)
# ========================================
# ANTHROPIC_API_KEY обязателен для работы Business-режима.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
# DEEPSEEK опционально — если пусто, фабрика откатится на Claude
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ENABLE_PROMPT_CACHE=True

# ========================================
# Контекст (бюджет токенов)
# ========================================
MAX_CONTEXT_TOKENS=100000
MAX_KNOWLEDGE_TOKENS=50000
MAX_HISTORY_MESSAGES=20
CONTEXT_RESERVE_TOKENS=4096

# ========================================
# Имитация живого ответа
# ========================================
HUMAN_RESPONSE_ENABLED=True
MIN_RESPONSE_DELAY=15.0
MAX_RESPONSE_DELAY=25.0
TYPING_CHARS_PER_SECOND=40.0
TYPING_MIN_DURATION=3.0
TYPING_MAX_DURATION=60.0

# ========================================
# Follow-up напоминания
# ========================================
FOLLOWUP_ENABLED=True
FOLLOWUP_CHECK_INTERVAL=60
FOLLOWUP_DELAY_MINUTES=60
FOLLOWUP_MAX_COUNT=1
